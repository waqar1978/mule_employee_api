<flow name="delete:/employee">

    <try>

        <set-variable variableName="empId" value="#[attributes.queryParams.empId]"/>

        <db:stored-procedure config-ref="DB_Config">
            <db:sql>
                <![CDATA[
                { call delete_employee(:emp_id) }
                ]]>
            </db:sql>
            <db:input-parameters>
                #[{ emp_id: vars.empId }]
            </db:input-parameters>
        </db:stored-procedure>

        <set-payload value='{"status":"DELETE SUCCESS"}' mimeType="application/json"/>

        <error-handler>
            <on-error-propagate logException="true">
                <set-payload value='{"status":"ERROR","message": "#[error.description]"}' mimeType="application/json"/>
            </on-error-propagate>
        </error-handler>

    </try>

</flow>
